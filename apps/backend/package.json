{
  "name": "@spicegarden/backend",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "echo \"lint placeholder\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --coverageThreshold=\"{\\\"global\\\":{\\\"branches\\\":80,\\\"functions\\\":80,\\\"lines\\\":80,\\\"statements\\\":80}}\"",
    "test:unit": "jest --testPathPattern=\"(order|kitchen|delivery).service.spec\"",
    "test:integration": "jest --testPathPattern=\".integration.\"",
    "test:e2e": "jest --testPathPattern=\"e2e.spec\"",
    "test:load": "k6 run test/load/10k-users.js",
    "test:load:20k": "k6 run test/load/20k-users.js",
    "test:load:breaking": "k6 run test/load/breaking-point.js",
    "test:chaos": "kubectl apply -f test/chaos/",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^10.0.0",
    "@sqltools/formatter": "^1.2.5",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "app-root-path": "^3.1.0",
    "argon2": "^0.40.0",
    "bcrypt": "^6.0.0",
    "crypto-js": "^4.2.0",
    "mongoose": "^8.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "helmet": "^7.1.0",
    "mongo-sanitize": "^1.1.0",
    "hpp": "^0.2.3",
    "express-rate-limit": "^7.1.5",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sha.js": "^2.4.12",
    "socket.io": "^4.7.0",
    "sql-highlight": "^6.1.0",
    "stripe": "^15.0.0",
    "typeorm": "^0.3.17"
  },
   "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/helmet": "^4.0.0",
    "@types/express-mongo-sanitize": "^2.1.0",
    "@types/hpp": "^0.2.2",
    "@types/express-rate-limit": "^6.0.0",
    "@types/express": "^4.17.17",
    "ansis": "^4.3.0",
    "jest": "^29.5.0",
    "k6": "^0.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
