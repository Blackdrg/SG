# SpiceGarden Environment Configuration
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3001

# Database - PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=spicegarden
DB_PASS=spicegarden
DB_NAME=spicegarden

# Database - MongoDB
MONGO_URI=mongodb://mongo:27017/spicegarden

# Database - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder

# Sentry
SENTRY_DSN=http://localhost:9000/1

# OpenSearch
OPENSEARCH_URL=https://opensearch:9200

# Monitoring
METRICS_ENABLED=true

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# External APIs
GOOGLE_MAPS_API_KEY=
SENDGRID_API_KEY=

# AlertManager
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=