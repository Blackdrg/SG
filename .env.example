# SpiceGarden Environment Configuration
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3001

# Database - PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=spicegarden
DB_PASS=
DB_NAME=spicegarden

# Database - MongoDB
MONGO_URI=mongodb://mongo:27017/spicegarden

# Database - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=

# OpenSearch
OPENSEARCH_URL=https://opensearch:9200

# Monitoring
METRICS_ENABLED=true

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# External APIs
GOOGLE_MAPS_API_KEY=
SENDGRID_API_KEY=