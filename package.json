{
  "name": "spicegarden",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run --workspaces dev",
    "build": "npm run --workspaces build",
    "lint": "npm run --workspaces lint",
    "format": "npm run --workspaces format",
    "test:unit": "npm run --workspaces test:unit",
    "test:integration": "npm run --workspaces test:integration",
    "test:e2e": "npm run --workspaces test:e2e",
    "test:all": "npm run --workspaces test:all"
  },
  "dependencies": {
    "mongodb": "^6.21.0"
  }
}
