{
  "name": "@spicegarden/customer-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "test:unit": "jest --testPathPattern=\"(order|kitchen|delivery).service.spec\" --passWithNoTests",
    "test:integration": "jest --testPathPattern=\".integration.\" --passWithNoTests",
    "test:e2e": "jest --testPathPattern=\"e2e.spec\" --passWithNoTests",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.0",
    "@spicegarden/ui": "*",
    "@tanstack/react-query": "^5.0.0",
    "lottie-react": "^2.4.1",
    "lottie-web": "^5.13.0",
    "next": "14.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.1.0",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "typescript": "^5.0.0"
  }
}
